# ============================================================================
# linux.fragment — Kernel Config Fragment for ZYBO Audio DSP
# ============================================================================
# Applied on top of xilinx_zynq_defconfig (linux-xlnx 5.15).
# Add this to your Buildroot defconfig via:
#   BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="board/zybo-z7/linux.fragment"

# ─── Sound / ALSA ───────────────────────────────────────────────────────────
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_SOC=y
CONFIG_SND_SOC_I2C_AND_SPI=y
CONFIG_SND_VERBOSE_PROCFS=y
CONFIG_SND_DEBUG=y
CONFIG_SND_PCM_XRUN_DEBUG=y

# ─── ASoC Simple Audio Card (allows pure-DT sound card configuration) ──────
CONFIG_SND_SIMPLE_CARD=y
CONFIG_SND_SIMPLE_CARD_UTILS=y

# ─── SSM2603 Codec Driver (mainline, 5.15+, compatible with SSM2602) ────
CONFIG_SND_SOC_SSM2602=y
CONFIG_SND_SOC_SSM2602_I2C=y

# ─── Xilinx DMA Engine ─────────────────────────────────────────────────────
CONFIG_DMADEVICES=y
CONFIG_XILINX_DMA=y
CONFIG_XILINX_DMA_ENGINE=y
CONFIG_AXI_DMAC=y

# ─── I2C ────────────────────────────────────────────────────────────────────
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_XILINX=y
CONFIG_I2C_CADENCE=y

# ─── GPIO ───────────────────────────────────────────────────────────────────
CONFIG_GPIO_SYSFS=y
CONFIG_GPIO_XILINX=y
CONFIG_GPIO_ZYNQ=y
CONFIG_GPIO_GENERIC_PLATFORM=y

# ─── SPI (for codec FW download, if needed) ─────────────────────────────────
CONFIG_SPI=y
CONFIG_SPI_XILINX=y
CONFIG_SPI_CADENCE=y

# ─── USB & Networking ──────────────────────────────────────────────────────
CONFIG_USB=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_ULPI=y
CONFIG_USB_GADGET=y
CONFIG_USB_ETH=y
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# ─── Filesystems ────────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_VFAT_FS=y
CONFIG_MSDOS_FS=y
CONFIG_FUSE_FS=y

# ─── UIO (userspace I/O — alternative to /dev/mem for DSP register access) ──
CONFIG_UIO=y
CONFIG_UIO_PDRV_GENIRQ=y
